#. i18n: ectx: label, entry (Users), group (General)
#: krdpserversettings.kcfg:32
#, kde-format
msgid "Users allowed to login, passwords are stored in KWallet"
msgstr ""
"Uživatelé, kteří mají povoleno přihlášení, mají hesla uložena v KWallet."

